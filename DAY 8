-- 1. Employees with salary greater than average salary
SELECT *
FROM employees
WHERE salary > (
    SELECT AVG(salary)
    FROM employees
);

-- 2. Products with price higher than cheapest ordered product
SELECT *
FROM products
WHERE price > (
    SELECT MIN(p.price)
    FROM products p
    INNER JOIN orders o
    ON p.product_id = o.product_id
);

-- 3. Customers who have orders
SELECT *
FROM customers
WHERE customer_id IN (
    SELECT customer_id
    FROM orders
);

-- 4. Show customer order counts
SELECT c.customer_id,
       c.customer_name,
       (
           SELECT COUNT(*)
           FROM orders o
           WHERE o.customer_id = c.customer_id
       ) AS total_orders
FROM customers c;

-- 5. Highest salary in each department
SELECT *
FROM employees e1
WHERE salary = (
    SELECT MAX(salary)
    FROM employees e2
    WHERE e1.department = e2.department
);

-- 6. Check if Laptop product exists
SELECT EXISTS (
    SELECT 1
    FROM products
    WHERE product_name = 'Laptop'
) AS product_exists;
